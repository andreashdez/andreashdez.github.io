{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:8080/", "http://127.0.0.1:8080/404.html"],
      "startServerCommand": "node scripts/quality-server.mjs 8080",
      "startServerReadyPattern": "Serving HTTP on",
      "numberOfRuns": 2
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:8080/$",
          "preset": "lighthouse:recommended",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.8 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["warn", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.95 }],
            "network-dependency-tree-insight": "warn"
          }
        },
        {
          "matchingUrlPattern": "^http://127\\.0\\.0\\.1:8080/404\\.html$",
          "preset": "lighthouse:recommended",
          "assertions": {
            "categories:performance": ["warn", { "minScore": 0.8 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["warn", { "minScore": 0.9 }],
            "categories:seo": "off",
            "is-crawlable": "off",
            "network-dependency-tree-insight": "warn"
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
